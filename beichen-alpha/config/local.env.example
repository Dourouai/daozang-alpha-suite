# Beichen custom bot webhook: one-way cards and alerts.
export FEISHU_WEBHOOK="https://open.feishu.cn/open-apis/bot/v2/hook/replace-me"
export FEISHU_SECRET=""

# daocang Feishu app settings: two-way group chat.
# Custom webhooks cannot receive messages; daocang uses event subscription and
# message reply permissions from a Feishu app.
export FEISHU_APP_ID=""
export FEISHU_APP_SECRET=""
export FEISHU_EVENT_VERIFY_TOKEN=""
export FEISHU_ENCRYPT_KEY=""
export FEISHU_CHAT_HOST="127.0.0.1"
export FEISHU_CHAT_PORT="8787"
export FEISHU_CHAT_ALLOW_WEBHOOK_FALLBACK="false"

# Server runner switches. P0 server default is conservative: Beichen runs
# healthcheck + trade plan and reads an existing Daozang score file if present.
# Enable the Daozang refresh switches only after installing Daozang research
# dependencies on the server.
export RUN_HEALTHCHECK="true"
export RUN_DAOZANG_SYNC_INDUSTRY_MAP="false"
export RUN_DAOZANG_SYNC_RISK_CALENDAR="false"
export RUN_DAOZANG_SYNC_UNIVERSE="false"
export RUN_DAOZANG_SYNC_QLIB_BARS="false"
export RUN_DAOZANG_EXPORT_BEICHEN_FEATURES="true"
export RUN_DAOZANG_BASELINE="auto"
export RUN_DAOZANG_EXPORT_SCORES="false"
export DAOZANG_QLIB_SYNC_WORKERS="8"
export DAOZANG_QLIB_SYNC_TIMEOUT="4"
export DAOZANG_BEICHEN_FEATURES_PATH="data/features/beichen_daily_features_latest.csv"
export RUN_POOL_REFRESH="false"
export RUN_TRADE_PLAN="true"
export RUN_FOCUS_CHECK="false"
export RUN_OUTCOME_BACKFILL="true"
export RUN_STRATEGY_PERFORMANCE="true"

# Fast data prewarm. This does not push Feishu by default; it refreshes a local
# latest trade-plan text cache so chat/manual reads do not wait on slow sources.
export BEICHEN_PREWARM_SOURCE="qlib"
export BEICHEN_PREWARM_QLIB_FALLBACK="true"
export BEICHEN_PREWARM_FULL_FACTORS="false"
export BEICHEN_PREWARM_TIMEOUT_SECONDS="240"
export BEICHEN_PREWARM_TRADE_PLAN_TEXT="data/runtime/latest_trade_plan.txt"
export BEICHEN_PREWARM_STATUS_JSON="data/runtime/latest_data_prewarm.json"
export BEICHEN_PREWARM_FACTORS="true"
export BEICHEN_PREWARM_FACTOR_TIMEOUT_SECONDS="240"
export BEICHEN_PREWARM_FACTOR_LIMIT="12"
export BEICHEN_PREWARM_FACTOR_STATUS_JSON="data/runtime/latest_factor_prewarm.json"
export BEICHEN_PREWARM_FLOW_JSON="data/runtime/latest_flow_snapshot.json"
export BEICHEN_PREWARM_GLOBAL_JSON="data/runtime/latest_global_linkage.json"
export BEICHEN_PREWARM_SENTIMENT_JSON="data/runtime/latest_sentiment_snapshot.json"
export BEICHEN_PREWARM_FLOW_DAILY="data/features/flow_daily.csv"
export BEICHEN_PREWARM_GLOBAL_DAILY="data/features/global_linkage_snapshot_daily.csv"
export BEICHEN_PREWARM_SENTIMENT_DAILY="data/features/sentiment_daily.csv"
export BEICHEN_PREWARM_COMBINED_DAILY="data/features/beichen_factor_daily.csv"

# Global linkage source set. Leave empty to use built-in defaults.
export BEICHEN_GLOBAL_FRED_SERIES=""
export BEICHEN_GLOBAL_YAHOO_TICKERS=""

# Position sizing inputs used by scripts/server_daily_run.sh.
export BEICHEN_CAPITAL="10000"
export BEICHEN_TRADE_TOP="3"
# Daozang model universe is the 800-stock base pond. Beichen can refresh the
# same broad pond, while trade plans may use a narrower actionable watchlist.
export BEICHEN_BROAD_POOL_SIZE="800"
export BEICHEN_BROAD_SCAN_LIMIT="800"
export BEICHEN_BROAD_WATCHLIST="data/watchlists/broad_target_pool_latest.txt"
export BEICHEN_TRADE_WATCHLIST="data/watchlists/trade_target_pool_latest.txt"
export BEICHEN_EXCLUDE_TRADE_GROUPS="能源,石油石化,煤炭,资源,材料资源"
export BEICHEN_PREFER_TRADE_GROUPS="医药,创新药"
export BEICHEN_STRATEGY_PERFORMANCE_REPORT="reports/strategy_performance_latest.txt"
export BEICHEN_STRATEGY_PERFORMANCE_MIN_SAMPLES="1"

# Feishu push discipline:
# - trade_decisions: default; only trading plans, holdings review, candidate triggers,
#   and intraday risk/action changes should go to Feishu.
# - all: also push data-maintenance reports such as pool refreshes.
# - off: never push automatically.
export BEICHEN_FEISHU_CHANNEL_MODE="trade_decisions"
export BEICHEN_FEISHU_SEND_POOL_REFRESH="false"
export BEICHEN_FEISHU_SEND_DAILY_CANDIDATES="false"
export BEICHEN_FEISHU_SEND_FOCUS_CHECK="true"
export BEICHEN_FEISHU_SEND_STRATEGY_PERFORMANCE="false"

# Intraday monitor. The historical script name still says 5min, but the
# systemd timer cadence is currently 10 minutes.
export BEICHEN_MONITOR_WATCHLIST="data/watchlists/current_focus_pool.txt"
export BEICHEN_MONITOR_POSITIONS="data/positions/current_positions.json"
export BEICHEN_MONITOR_INTERVAL_SECONDS="600"
export BEICHEN_MONITOR_NOTIFY="auto"
export BEICHEN_MONITOR_MAX_LOT_COST="10000"

# Optional P1 paid/permissioned source. Leave empty to keep the system on
# AKShare/东方财富/BaoStock/Qlib/Daozang local CSVs only.
export TUSHARE_TOKEN=""
export TUSHARE_API_URL="http://api.tushare.pro"
export TUSHARE_TIMEOUT="10"
