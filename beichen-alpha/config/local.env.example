export FEISHU_WEBHOOK="https://open.feishu.cn/open-apis/bot/v2/hook/replace-me"
export FEISHU_SECRET=""

# Server runner switches. The daily runner is conservative by default:
# it runs healthcheck + trade plan, and leaves heavier refresh/realtime checks opt-in.
export RUN_HEALTHCHECK="true"
export RUN_POOL_REFRESH="false"
export RUN_TRADE_PLAN="true"
export RUN_FOCUS_CHECK="false"

# Position sizing inputs used by scripts/server_daily_run.sh.
export BEICHEN_CAPITAL="10000"
export BEICHEN_TRADE_TOP="3"
